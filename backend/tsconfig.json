{
  "extends": "../tsconfig.base.json",
  "compilerOptions": { 
    "outDir": "dist",
    "module": "NodeNext",
    "target": "ES2020",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noImplicitAny":false,
    "strict": false,
    "skipLibCheck":true
  },
  "include": ["src"]
}
