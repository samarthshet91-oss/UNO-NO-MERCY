{
  "extends": "../tsconfig.base.json",
  "compilerOptions": { 
    "outDir": "dist",
    "target": "ES2020",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noImplicitAny":false,
    "strict": false,
    "skipLibCheck":true,
    "allowJs":true,
    "module":"CommonJS"
  },
  "include": ["src","../shared/src"]
}
