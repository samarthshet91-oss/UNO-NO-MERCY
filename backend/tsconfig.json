{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@arc-blitz/shared":["../shared/dist/index.d.ts"]
    },
    "outDir": "dist",
    "rootDir": "src",
    "module": "ESNext",
    "target": "ES2020",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noImplicitAny":false,
    "strict": false,
    "skipLibCheck": true
  },
  "include": ["src"]
}
